    {
      "id": "evGbqNvPyIPikpKzx_8IH",
      "type": "text",
      "x": 3825.282759599033,
      "y": 1323.6431307158798,
      "width": 495.3599853515625,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
