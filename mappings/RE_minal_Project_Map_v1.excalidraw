    {
      "id": "7jOPpKt3_Fsfnqtcd8Ja8",
      "type": "text",
      "x": 3889.2027425091887,
      "y": 1162.30000871588,
      "width": 367.52001953125,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
