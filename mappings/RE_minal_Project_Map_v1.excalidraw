      "locked": false,
      "text": "日常に溶け込んで\n自然な会話ができる",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "KoG4VOijTSRzSuolnU53U",
      "originalText": "日常に溶け込んで\n自然な会話ができる",
      "autoResize": true,
      "lineHeight": 1.25
    },
