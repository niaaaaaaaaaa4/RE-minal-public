      "updated": 1781521837075,
      "link": null,
      "locked": false,
      "text": "会話だけで\n断片的な、放り投げた記憶を\n記録してくれる",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "rcbE6BvApp_V6bwFG6bZG",
      "originalText": "会話だけで\n断片的な、放り投げた記憶を\n記録してくれる",
      "autoResize": true,
      "lineHeight": 1.25
    },
