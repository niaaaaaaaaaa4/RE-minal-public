      "boundElements": null,
      "updated": 1781521837075,
      "link": null,
      "locked": false,
      "text": "語尾は断定する「～だろう。」「～だと。」",
      "fontSize": 14.921668818031174,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "sag1bdYU3DA2sSN1iYSgx",
      "originalText": "語尾は断定する「～だろう。」「～だと。」",
      "autoResize": true,
      "lineHeight": 1.25
    },
