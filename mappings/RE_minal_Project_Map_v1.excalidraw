    {
      "id": "MNPqeLy9086FgXOIp7bmy",
      "type": "text",
      "x": 5101.924198120001,
      "y": 969.7539228740486,
      "width": 278.03411865234375,
      "height": 55.9562580676169,
      "angle": 0,
